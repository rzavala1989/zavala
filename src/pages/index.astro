---
import Base from '../layouts/Base.astro';
---

<Base title="Ricardo Zavala — Principal Engineer">
  <main class="container">
    <h1 class="name">Ricardo Zavala</h1>
    <p class="title">Principal Engineer</p>
    <div class="divider"></div>
    <a class="link" href="https://github.com/rzavala1989" target="_blank" rel="noopener noreferrer">
      github.com/rzavala1989
    </a>
    <p class="soon">More coming soon.</p>
  </main>
</Base>

<style>
  .container {
    text-align: center;
    padding: 2rem;
  }

  .name {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .title {
    font-weight: 500;
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6b6560;
    margin-top: 1.2rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
  }

  .divider {
    width: 40px;
    height: 1px;
    background-color: #c8c2bc;
    margin: 2.4rem auto;
    opacity: 0;
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  .link {
    display: inline-block;
    font-size: clamp(0.85rem, 1.5vw, 0.95rem);
    font-weight: 500;
    color: #1a1a1a;
    text-decoration: none;
    letter-spacing: 0.03em;
    padding: 0.4rem 0;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
    transition: color 0.3s ease;
  }

  .link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: #1a1a1a;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .link:hover {
    color: #8b7355;
  }

  .link:hover::after {
    background-color: #8b7355;
    transform: scaleX(1);
    transform-origin: left;
  }

  .soon {
    font-size: clamp(0.75rem, 1.2vw, 0.8rem);
    font-weight: 400;
    color: #b0aaa4;
    letter-spacing: 0.08em;
    margin-top: 4rem;
    opacity: 0;
    animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
  }

  @media (max-width: 480px) {
    .divider {
      margin: 1.8rem auto;
    }

    .soon {
      margin-top: 3rem;
    }
  }
</style>
